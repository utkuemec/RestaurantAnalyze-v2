<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="theme-color" content="#1B2E5C">
    <title>Recommendations — MADO</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Dancing+Script:wght@600;700&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <div class="scroll-progress"></div>

    <nav class="navbar">
        <div class="navbar-inner">
            <a href="/" class="navbar-brand">
                <span class="logo-text">MADO</span>
                <span class="logo-sub">Cafe &amp;<br>Bakery</span>
            </a>
            <div style="display:flex;align-items:center;">
                <div class="navbar-links">
                    <a href="/">Home</a>
                    <a href="/recommend">Recommend</a>
                    <a href="/menu">Full Menu</a>
                </div>
                <button class="navbar-cart" title="View Cart">&#128722;<span class="cart-badge"></span></button>
            </div>
        </div>
    </nav>

    <div class="page-wrapper">

        <div class="results-header reveal">
            <div>
                <h1>Your Recommendations</h1>
                <div class="query-info">
                    <% if (food) { %><span class="query-tag"><%= food %></span><% } %>
                    <% if (food && drink) { %>&amp;<% } %>
                    <% if (drink) { %><span class="query-tag"><%= drink %></span><% } %>
                </div>
            </div>
            <a href="/recommend" class="btn btn-outline">&#8592; Try Again</a>
        </div>

        <h2 class="section-title reveal">Recommended Foods</h2>

        <% if (data.recommended_foods && data.recommended_foods.length > 0) { %>
            <div class="items-grid stagger-children">
                <% data.recommended_foods.slice(0, 5).forEach(function(item, i) { %>
                    <div class="item-card reveal" data-item="<%= item.name %>">
                        <div class="item-top-row">
                            <div class="item-rank"><%= i + 1 %></div>
                            <button class="add-cart-btn" data-item="<%= item.name %>" data-price="<%= item.price.toFixed(2) %>" data-category="<%= item.category %>">
                                <span class="cart-icon">+</span> Add to Cart
                            </button>
                        </div>
                        <div class="item-name"><%= item.name %></div>
                        <div class="item-category"><%= item.category %></div>
                        <div class="item-desc"><%= item.description %></div>
                        <div class="item-bottom">
                            <span class="item-price">$<%= item.price.toFixed(2) %></span>
                            <% if (item.score) { %>
                                <span class="match-score"><%= item.score %>% match</span>
                            <% } %>
                        </div>
                        <div class="similar-toggle" data-item="<%= item.name %>">Show similar &#9662;</div>
                        <div class="similar-container" id="similar-<%= item.name.replace(/[^a-zA-Z0-9]/g, '_') %>" style="display:none;"></div>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <div class="empty-state reveal">
                <div class="icon">&#128533;</div>
                <p>No food matches found for "<%= food %>". Try a different keyword.</p>
            </div>
        <% } %>

        <div class="watercolor-divider"></div>

        <h2 class="section-title reveal">Recommended Drinks</h2>

        <% if (data.recommended_drinks && data.recommended_drinks.length > 0) { %>
            <div class="items-grid stagger-children">
                <% data.recommended_drinks.slice(0, 5).forEach(function(item, i) { %>
                    <div class="item-card reveal" data-item="<%= item.name %>">
                        <div class="item-top-row">
                            <div class="item-rank"><%= i + 1 %></div>
                            <button class="add-cart-btn" data-item="<%= item.name %>" data-price="<%= item.price.toFixed(2) %>" data-category="<%= item.category %>">
                                <span class="cart-icon">+</span> Add to Cart
                            </button>
                        </div>
                        <div class="item-name"><%= item.name %></div>
                        <div class="item-category"><%= item.category %></div>
                        <div class="item-desc"><%= item.description %></div>
                        <div class="item-bottom">
                            <span class="item-price">$<%= item.price.toFixed(2) %></span>
                            <% if (item.score) { %>
                                <span class="match-score"><%= item.score %>% match</span>
                            <% } %>
                        </div>
                        <div class="similar-toggle" data-item="<%= item.name %>">Show similar &#9662;</div>
                        <div class="similar-container" id="similar-<%= item.name.replace(/[^a-zA-Z0-9]/g, '_') %>" style="display:none;"></div>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <div class="empty-state reveal">
                <div class="icon">&#128533;</div>
                <p>No drink matches found for "<%= drink %>". Try a different keyword.</p>
            </div>
        <% } %>

        <div style="text-align:center; margin-top: 2rem;" class="reveal">
            <a href="/recommend" class="btn btn-primary">Search Again</a>
        </div>

        <% if (menu) { %>
        <div class="watercolor-divider"></div>

        <div class="full-menu-section">
            <h2 class="section-title">Full Menu</h2>

            <% var foodsByCategory = {}; %>
            <% if (menu.Foods) { menu.Foods.forEach(function(item) { if (!foodsByCategory[item.category]) foodsByCategory[item.category] = []; foodsByCategory[item.category].push(item); }); } %>
            <% var drinksByCategory = {}; %>
            <% if (menu.Drinks) { menu.Drinks.forEach(function(item) { if (!drinksByCategory[item.category]) drinksByCategory[item.category] = []; drinksByCategory[item.category].push(item); }); } %>

            <% Object.keys(foodsByCategory).forEach(function(cat) { %>
                <div class="menu-category-title"><%= cat %></div>
                <div class="menu-table-wrap">
                    <table class="menu-table">
                        <thead><tr><th>Item</th><th>Description</th><th>Price</th><th></th></tr></thead>
                        <tbody>
                        <% foodsByCategory[cat].forEach(function(item) { %>
                            <tr>
                                <td class="menu-item-name"><%= item.name %></td>
                                <td class="menu-item-desc"><%= item.description %></td>
                                <td class="menu-item-price">$<%= item.price.toFixed(2) %></td>
                                <td><button class="add-cart-btn-sm" data-item="<%= item.name %>" data-price="<%= item.price.toFixed(2) %>" data-category="<%= cat %>"><span class="cart-icon">+</span> Add</button></td>
                            </tr>
                        <% }); %>
                        </tbody>
                    </table>
                </div>
            <% }); %>

            <% Object.keys(drinksByCategory).forEach(function(cat) { %>
                <div class="menu-category-title"><%= cat %></div>
                <div class="menu-table-wrap">
                    <table class="menu-table">
                        <thead><tr><th>Item</th><th>Description</th><th>Price</th><th></th></tr></thead>
                        <tbody>
                        <% drinksByCategory[cat].forEach(function(item) { %>
                            <tr>
                                <td class="menu-item-name"><%= item.name %></td>
                                <td class="menu-item-desc"><%= item.description %></td>
                                <td class="menu-item-price">$<%= item.price.toFixed(2) %></td>
                                <td><button class="add-cart-btn-sm" data-item="<%= item.name %>" data-price="<%= item.price.toFixed(2) %>" data-category="<%= cat %>"><span class="cart-icon">+</span> Add</button></td>
                            </tr>
                        <% }); %>
                        </tbody>
                    </table>
                </div>
            <% }); %>
        </div>
        <% } %>

        <div class="footer">
            <span class="footer-brand">MADO</span>
            <div class="footer-tagline">Ice Cream &middot; Cafe &middot; Bakery</div>
            <div class="footer-year">&copy; 2026 MADO Canada. All rights reserved.</div>
        </div>
    </div>

    <div id="toast" class="toast"></div>
    <script src="/app.js"></script>
    <script src="/cart.js"></script>
    <script src="/chat-widget.js"></script>
</body>
</html>
